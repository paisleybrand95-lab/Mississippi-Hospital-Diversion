{
  "name": "mississippi-hospital-diversion",
  "version": "1.0.0",
  "private": true,
  "description": "Mississippi Hospital Diversion Status App — Real-time EMS network for MS hospitals",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "@capacitor/core": "^7.1.0",
    "@capacitor/app": "^7.1.0",
    "@capacitor/geolocation": "^7.1.0",
    "@capacitor/haptics": "^7.1.0",
    "@capacitor/local-notifications": "^7.1.0",
    "@capacitor/network": "^7.1.0",
    "@capacitor/splash-screen": "^7.1.0",
    "@capacitor/status-bar": "^7.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.0",
    "@capacitor/ios": "^7.1.0",
    "@capacitor/android": "^7.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "cap:build": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:update": "npx cap sync"
  },
  "eslintConfig": {
    "extends": ["react-app"]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  },
  "keywords": ["EMS", "Mississippi", "hospital", "diversion", "public-safety"],
  "author": "Bryan \"BW\" White",
  "license": "UNLICENSED"
}
