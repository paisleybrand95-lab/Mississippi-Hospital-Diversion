# ─────────────────────────────────────────────────────────────────────────────
# .env.local — MS Hospital Diversion Firebase Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# SETUP:
#   1. Copy this file to .env.local (already in .gitignore — never commit secrets)
#   2. Go to Firebase Console → Project Settings → Your Apps → Web App
#   3. Copy each value from your firebaseConfig object
#   4. Restart the dev server: npm start
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_FIREBASE_API_KEY=YOUR_API_KEY_HERE
REACT_APP_FIREBASE_AUTH_DOMAIN=ms-hospital-diversion.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=ms-hospital-diversion
REACT_APP_FIREBASE_STORAGE_BUCKET=ms-hospital-diversion.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
REACT_APP_FIREBASE_APP_ID=YOUR_APP_ID_HERE
REACT_APP_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID_HERE

# VAPID Key — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
REACT_APP_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE
